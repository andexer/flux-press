{
    "name": "Social & Profile",
    "description": "Diseño personal para creadores de contenido, influencers y portfolios. Enfocado en visibilidad y engagement social.",
    "category": "social",
    "thumbnail": "",
    "version": "1.0",
    "schema_version": "1.0",
    "settings": {
        "header": {
            "style": "minimal",
            "sticky": true,
            "mega_menu": {
                "enabled": false,
